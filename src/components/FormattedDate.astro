---
interface Props {
	date?: Date;
}

const { date } = Astro.props;
const isValidDate = date instanceof Date && !Number.isNaN(date.getTime());
---

{
	isValidDate && (
		<time datetime={date.toISOString()}>
			{date.toLocaleDateString('ja-JP', {
				year: 'numeric',
				month: 'short',
				day: 'numeric',
			})}
		</time>
	)
}
