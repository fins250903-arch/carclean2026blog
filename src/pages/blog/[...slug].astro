---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { resolvePostImage } from '../../utils/seo';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => {
		const slug = post.id.replace(/\/index$/, '');
		return {
			params: { slug },
			props: post,
		};
	});
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const postSlug = post.id.replace(/\/index$/, '');
const heroImage = resolvePostImage(post.data.coverImage, postSlug) ?? null;
const ogImage = resolvePostImage(post.data.ogp?.og_image, postSlug) ?? heroImage;
const postData = { ...post.data, heroImage, ogImage };
const { Content } = await render(post);
---

<BlogPost {...postData}>
	<Content />
</BlogPost>
